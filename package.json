{
  "name": "action-slack-deploy-pipeline",
  "description": "Post GitHub Action deploy workflow progress notifications to Slack",
  "version": "0.0.0",
  "author": "Nick Amoscato <nick@amoscato.com>",
  "private": true,
  "homepage": "https://github.com/marketplace/actions/slack-deploy-pipeline-notifications",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Fieldguide/action-slack-deploy-pipeline.git"
  },
  "bugs": {
    "url": "https://github.com/Fieldguide/action-slack-deploy-pipeline/issues"
  },
  "keywords": [
    "actions",
    "slack",
    "deployment",
    "pipeline",
    "workflow",
    "notifications",
    "progress"
  ],
  "exports": {
    "notifySlack": "./dist/notifySlack/index.js",
    "generateUserMapping": "./dist/generateUserMapping/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.12.4",
  "scripts": {
    "dev": "pnpm package:notifySlack --watch & pnpm package:generateUserMapping --watch",
    "bundle": "pnpm format:write && pnpm package:notifySlack && pnpm package:generateUserMapping",
    "format:write": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --ext .ts",
    "package:notifySlack": "ncc build src/notifySlack.ts -o dist/notifySlack --license licenses.txt",
    "package:generateUserMapping": "ncc build src/generateUserMapping.ts -o dist/generateUserMapping --license licenses.txt",
    "test": "jest --watch",
    "test:ci": "jest",
    "all": "pnpm format:check && pnpm lint && pnpm test:ci && pnpm package:notifySlack && pnpm package:generateUserMapping"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.1",
    "@slack/web-api": "^7.11.0",
    "date-fns": "^4.1.0",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@octokit/types": "^15.0.0",
    "@octokit/webhooks-types": "^7.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.21",
    "@typescript-eslint/parser": "^7.9.0",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^8.57.0",
    "eslint-plugin-github": "^4.10.2",
    "eslint-plugin-jest": "^28.5.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^30.2.0",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.5",
    "typescript": "^5.9.3"
  }
}
